      - rid: 4841317357165477896
  m_TableData:
  - m_Id: 50305010928328704
    m_Localized: Kapelusz błazna
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51317535027372032
    m_Localized: Powrót na szczyt
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202624
    m_Localized: Pancernik
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202625
    m_Localized: Dzika premia
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202626
    m_Localized: Twoja tarcza, panie
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50305010953494528
    m_Localized: Dodaje Dziką kartę do ręki na początku każdego piętra.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51317535044149248
    m_Localized: Gdy odkrywca odejdzie, zostanie odłożony na wierzch talii.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202630
    m_Localized: Zadaje obrażenia równe Pancerzowi pierwszemu rzędowi po zagraniu karty Pancerza.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202631
    m_Localized: Karty pozyskane ze źródeł świata teraz zyskują na mnożnikach combo.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202632
    m_Localized: Pozostały {GlobalKeywords.Armor} nie znika między turami.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171049999507456
    m_Localized: Jeszcze raz
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577568325632
    m_Localized: Ogniwo łańcucha
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891761041408
    m_Localized: Cała naprzód
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517646008321
    m_Localized: Na czarną godzinę
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171050016284672
    m_Localized: Karta jest bezpłatna, jeśli jej wersja została już zagrana w tej kolejce.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577597685760
    m_Localized: Combo nie zostają przerwane między kolejkami.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891786207232
    m_Localized: Aktywuje specjalne umiejętności odkrywcy za darmo na początku każdej kolejki.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202629
    m_Localized: Zachowaj Manę (maks. {Arcana.EffectValue.0:N0}) między kolejkami.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324314165248
    m_Localized: Syfon Many
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324335136768
    m_Localized: Na stale zwiększa Manę po każdych {Arcana.EffectValue.1:N0} zagranych kartach.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967023235072
    m_Localized: Spuchnięta ręka
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967035817984
    m_Localized: Zadaje obrażenia zależne od rozmiaru Stosu kart na koniec każdej kolejki.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 69086584003178496
    m_Localized: Eksperymentalny lek
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 69086584024150016
    m_Localized: Podwaja wszystkie uzdrawiające efekty.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384826499072
    m_Localized: Dodaje Dziką kartę na każdym piętrze.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053504
    m_Localized: Przenosi odkrywców na wierzch Talii.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053505
    m_Localized: Użycie powoduje obrażenia równe Pancerzowi.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053506
    m_Localized: Karty ze źródeł świata zyskują mnożniki combo.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053507
    m_Localized: '{GlobalKeywords.Armor} nie znika.'
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053508
    m_Localized: Karty powtórzone w tej kolejce są bezpłatne.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053509
    m_Localized: Combo nie zostają przerwane między kolejkami.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053510
    m_Localized: Aktywuje umiejętności na początku kolejki.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053511
    m_Localized: Zachowaj Manę (maks. {Arcana.EffectValue.0:N0}) między kolejkami.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053512
    m_Localized: Zwiększa Manę po każdych {Arcana.EffectValue.1:N0} kartach.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053513
    m_Localized: Zadaje obrażenia zależne od Stosu kart po kolejce.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053514
    m_Localized: Podwójne uzdrawianie.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 164759920689754112
    m_Localized: Po zakończeniu kolejki zadaje obrażenia równe {Arcana.EffectValue.0:N0}x liczbie kart w twoim Stosie kart.
    m_Metadata:
      m_Items:
        Array:
        - rid: 4841317358791295112
  - m_Id: 164759920714919936
    m_Localized: Zadaje obrażenia zależne od Stosu kart po zakończeniu kolejki.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 164759920714919937
    m_Localized: Zadaje obrażenia równe {Arcana.EffectValue.0:N0}x rozmiarowi twojego Stosu kart na końcu każdej kolejki.
    m_Metadata:
      m_Items:
        Array:
        - rid: 4841317358791295112

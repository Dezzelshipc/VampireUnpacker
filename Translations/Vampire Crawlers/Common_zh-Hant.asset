  m_TableData:
  - m_Id: 7491985282686976
    m_Localized: "敬請確認並套用你的顯示設定選項，否則的話，\n系統即會在 {0} 秒後還原你既有的顯示設定⋯⋯"
    m_Metadata:
      m_Items:
        Array:
        - rid: 5248835630640398453
  - m_Id: 2329695739904
    m_Localized: '{0}。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 5248835630640398453
  - m_Id: 94237927729520640
    m_Localized: 儲存失敗
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 94237927788240896
    m_Localized: 無法將存檔資料寫入磁碟中。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 94237927788240897
    m_Localized: 載入失敗
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 94237927788240898
    m_Localized: 無法自磁碟讀取存檔資料。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 94237927788240899
    m_Localized: 存檔毀損
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 94237927788240900
    m_Localized: 偵測到存檔資料毀損。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 779383265505280
    m_Localized: 請問你確定要刪除此筆資料嗎？
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 779383328419840
    m_Localized: 要放棄探索地城並返回{GlobalKeywords.Village}嗎？
    m_Metadata:
      m_Items:
        Array:
        - rid: 5248835630640398453
  - m_Id: 779383328419841
    m_Localized: 返回主選單？
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 4663173691990016
    m_Localized: 目前還有尚未儲存的變更。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 7911158307565568
    m_Localized: "你在村莊中醒來，頭感覺有點痛⋯⋯\n你心裡想著：我本來不是在地城中冒險嗎？還是我精神錯亂了？\n難道是開發人員不小心動到了存檔資料嗎？\n好煩啊⋯⋯"
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 19869313610539008
    m_Localized: 未偵測到控制器
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 19869313610539009
    m_Localized: 請連接控制器，並選擇「確定」以繼續至下一步
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 19869313610539010
    m_Localized: 由 Nosebleed Interactive 所製作的好玩遊戲
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 22485624548306944
    m_Localized: 確定要退出 {GlobalKeywords.VampireCrawlers} 嗎？
    m_Metadata:
      m_Items:
        Array:
        - rid: 5248835630640398453
  - m_Id: 28178546303119360
    m_Localized: 未偵測到控制器
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 28178546332479488
    m_Localized: 選擇「確定」以繼續至下一步
    m_Metadata:
      m_Items:
        Array: []

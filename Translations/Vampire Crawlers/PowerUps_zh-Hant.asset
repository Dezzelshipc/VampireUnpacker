  m_Script: {fileID: 11500000, guid: 1aac8e9c81dd1c685a0bf64c67249e0c, type: 3}
  m_Name: PowerUps_zh-Hant
  m_EditorClassIdentifier:
  m_LocaleId:
    m_Code: zh-Hant
  m_SharedData: {fileID: 11400000, guid: 7054dfbaed23aa44195a1ac88261e50f, type: 2}
  m_Metadata:
    m_Items:
      Array:
      - rid: 1186001538324365324
  m_TableData:
  - m_Id: 1803676626944
    m_Localized: 每一級能夠對目標造成額外 {PowerUpValue:N0}% 的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615731089408
    m_Localized: 提高傷害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 1803680821249
    m_Localized: 每一級能夠提高 {PowerUpValue:N0} 點的{GlobalKeywords.Armor}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615756255232
    m_Localized: 減少受到的傷害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 1803680821251
    m_Localized: 每一級能夠提高 {PowerUpValue:N0}% 的{GlobalKeywords.MaxHealth}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615756255233
    m_Localized: 提高{GlobalKeywords.MaxHealth}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 4891401596929
    m_Localized: 每一級能夠提高 {PowerUpValue:N0} 點的{GlobalKeywords.Mana}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615756255234
    m_Localized: 提高{GlobalKeywords.Mana}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 4891401596931
    m_Localized: 在每一場戰鬥過後，每一級能夠為你恢復 {PowerUpValue:N0} 點的生命值。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449536
    m_Localized: 在戰鬥過後，讓你能夠恢復生命值。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 14110645366784
    m_Localized: 每一級能夠讓武器額外發射 {PowerUpValue:N0} 個{PowerUpValue:p:投射物|投射物}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449537
    m_Localized: 武器能發射更多投射物。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 14110645366786
    m_Localized: 攻擊造成濺射傷害。每階級 {PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449538
    m_Localized: 濺射傷害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 23295198048257
    m_Localized: 每一級能夠讓你額外獲得 {PowerUpValue:N0}% 的經驗值。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449539
    m_Localized: 獲得更多的經驗值。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 23295198048259
    m_Localized: 每一級能夠讓你額外獲得 {PowerUpValue:N0}% 的金幣。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449540
    m_Localized: 獲得更多的金幣。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 23295198048261
    m_Localized: 每一級能夠提高 {PowerUpValue:N0}% 的{GlobalKeywords.Luck}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449541
    m_Localized: 提高超好運的觸發機率。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2192685012168704
    m_Localized: 強化你的抽牌效果，每一級能夠讓你額外抽取 {PowerUpValue:N0} 張{PowerUpValue:p:卡牌|卡牌}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449542
    m_Localized: 增加「抽牌」效果的抽取卡牌數。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2192685012168706
    m_Localized: 提高你的{GlobalKeywords.Handsize}上限，每一級能夠讓你的手牌上限多 {PowerUpValue:N0} 張{PowerUpValue:p:卡牌|卡牌}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449543
    m_Localized: 提高{GlobalKeywords.Handsize}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 2283735013732352
    m_Localized: 每一級能夠延長{GlobalKeywords.Crawlers}停留的{GlobalKeywords.Duration} 達 {PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449544
    m_Localized: 提高{GlobalKeywords.Crawlers}的輔助效果觸發次數。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 2283735013732354
    m_Localized: 每一級能夠讓你在選擇升級項目時，移除 {PowerUpValue:N0} 張你不想要的{PowerUpValue:p:卡牌|卡牌}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449545
    m_Localized: 讓你可以在選擇升級項目時，移除你不想要的卡牌。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2283735013732356
    m_Localized: 每一級能夠讓你多獲得 {PowerUpValue:N0} 次的升級項目{GlobalKeywords.Reroll}機會。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449546
    m_Localized: 升級項目的{GlobalKeywords.Reroll}機會。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 2283735013732358
    m_Localized: '{GlobalKeywords.Skip}挑選環節並改為獲得經驗值，每一級能夠讓你多獲得 {PowerUpValue:N0} 點的經驗值。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449547
    m_Localized: '{GlobalKeywords.Skip}挑選環節並改為獲得經驗值。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 2541682885210112
    m_Localized: 在你的生命值歸零之後，每一級可以讓你{GlobalKeywords.Revive}一次。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449548
    m_Localized: 在你的生命值歸零之後，讓你可以{GlobalKeywords.Revive}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 18138219010928640
    m_Localized: 每一級會強化敵人的能力達 {PowerUpValue:N0}%，但你可以藉此獲得額外的經驗值。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 84069615760449550
    m_Localized: 強化敵人的能力，但你可以藉此獲得額外的經驗值。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 43555440361025536
    m_Localized: 每一級能夠增加一個額外的{GlobalKeywords.Crawler}欄位。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 96079886660087808
    m_Localized: 每一級能夠使敵人的速度、生命值與出現數量提高 {PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 170475265769549824
    m_Localized: 多次打擊目標。每一級的倍率為 {PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365324
  - m_Id: 170475265794715648
    m_Localized: 多次打擊目標。
    m_Metadata:
      m_Items:
        Array: []
  references: {}

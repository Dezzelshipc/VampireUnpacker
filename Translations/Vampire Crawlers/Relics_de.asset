  m_TableData:
  - m_Id: 633881047040
    m_Localized: Karte der Milchstraße
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018560
    m_Localized: Die Minimap zeigt Feinde und andere Dinge.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018561
    m_Localized: Grimmiges Grimoire
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018562
    m_Localized: Entdeckte Waffenverbesserungen und -vereinigungen werden im Pausenmenü angezeigt.
    m_Metadata:
      m_Items:
        Array: []

  m_TableData:
  - m_Id: 50305010928328704
    m_Localized: 小丑帽
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51317535027372032
    m_Localized: 后来居上
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202624
    m_Localized: 护盾猛击
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202625
    m_Localized: 万能增益
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202626
    m_Localized: 甲不离身
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50305010953494528
    m_Localized: 在每层开始时，向你的{GlobalKeywords.Deck}添加一张万能牌。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 51317535044149248
    m_Localized: 当一名{GlobalKeywords.Crawler}离开时，将其放在你的{GlobalKeywords.Deck}的最上方。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 2090517650202630
    m_Localized: 在打出一张{GlobalKeywords.Armor}牌后，对前排敌人造成相当于{GlobalKeywords.Armor}总值的伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 2090517650202631
    m_Localized: 从光源中拾取的卡牌现在可获得连击倍数增益。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202632
    m_Localized: 剩余{GlobalKeywords.Armor}可留存到后续回合。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 53171049999507456
    m_Localized: 免费续杯
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577568325632
    m_Localized: 连击不绝
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891761041408
    m_Localized: 闪亮登场
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517646008321
    m_Localized: 锐意不减
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171050016284672
    m_Localized: 本回合内如果已打出卡牌的某个版本，则再次打出时{GlobalKeywords.TypeFree}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 53870577597685760
    m_Localized: 连击数在回合结束时不清零。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891786207232
    m_Localized: 在每回合开始时，免费激活{GlobalKeywords.Crawler}触发能力。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 2090517650202629
    m_Localized: 至多将{Arcana.EffectValue.0:N0}点{GlobalKeywords.Mana}保留到下一回合。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 68412324314165248
    m_Localized: 法力虹吸
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324335136768
    m_Localized: 每打出{Arcana.EffectValue.1:N0}张牌后，{GlobalKeywords.Mana}永久增加。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 68794967023235072
    m_Localized: 肿胀拳头
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967035817984
    m_Localized: 在每回合结束时，基于{GlobalKeywords.DeckPile}的牌数造成伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 69086584003178496
    m_Localized: 实验医学
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 69086584024150016
    m_Localized: 所有治疗效果翻倍。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384826499072
    m_Localized: 每层添加一张万能牌。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053504
    m_Localized: 将{GlobalKeywords.Crawlers}移到{GlobalKeywords.Deck}最上方。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 91224384860053505
    m_Localized: 打出时造成相当于{GlobalKeywords.Armor}的伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 91224384860053506
    m_Localized: 从光源中拾取的卡牌获得连击倍数。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053507
    m_Localized: '{GlobalKeywords.Armor}可留存到后续回合。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 91224384860053508
    m_Localized: 重复卡牌本回合免费。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053509
    m_Localized: 连击数在回合结束时不清零。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053510
    m_Localized: 回合开始时触发能力。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053511
    m_Localized: 至多将{Arcana.EffectValue.0:N0}点{GlobalKeywords.Mana}保留到下一回合。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 91224384860053512
    m_Localized: 每打出{Arcana.EffectValue.1:N0}张牌，{GlobalKeywords.Mana}增加。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 91224384860053513
    m_Localized: 回合结束后造成相当于{GlobalKeywords.DeckPile}牌数的伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 91224384860053514
    m_Localized: 治疗效果翻倍。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 164759920689754112
    m_Localized: 回合结束后造成{Arcana.EffectValue.0:N0}x{GlobalKeywords.DeckPile}牌数的伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 164759920714919936
    m_Localized: 回合结束后基于{GlobalKeywords.DeckPile}牌数造成伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365340
  - m_Id: 164759920714919937
    m_Localized: 在每回合结束时，造成相当于{Arcana.EffectValue.0:N0}倍{GlobalKeywords.DeckPile}牌数的伤害。

--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1aac8e9c81dd1c685a0bf64c67249e0c, type: 3}
  m_Name: Arcanas_zh-Hant
  m_EditorClassIdentifier:
  m_LocaleId:
    m_Code: zh-Hant
  m_SharedData: {fileID: 11400000, guid: 085822551f16911449a5d6f0b850ec8e, type: 2}
  m_Metadata:
    m_Items:
      Array:
      - rid: 1186001538324365316
  m_TableData:
  - m_Id: 50305010928328704
    m_Localized: 小丑帽
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51317535027372032
    m_Localized: 登峰造極
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202624
    m_Localized: 盾牌猛擊
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202625
    m_Localized: 野性增益
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202626
    m_Localized: 主公，您的盾牌在此
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50305010953494528
    m_Localized: 在開始探索每一層地城的時候，將一張萬用卡加入你的{GlobalKeywords.Deck}中。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 51317535044149248
    m_Localized: 在{GlobalKeywords.Crawler}退去之時，將該名冒險者置於你{GlobalKeywords.Deck}的頂端。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 2090517650202630
    m_Localized: 打出{GlobalKeywords.Armor}卡牌後，對前排造成等同於你{GlobalKeywords.Armor}總值的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 2090517650202631
    m_Localized: 從光源處拾取的卡牌現在可受益於連段加成。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202632
    m_Localized: 剩餘的{GlobalKeywords.Armor}效果會持續至下一回合。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 53171049999507456
    m_Localized: 再來一張
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577568325632
    m_Localized: 連鎖效應
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891761041408
    m_Localized: 小題大作
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517646008321
    m_Localized: 敏銳心智
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171050016284672
    m_Localized: 若本回合已打出過同名的卡牌，那麼該卡牌就會是{GlobalKeywords.TypeFree}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 53870577597685760
    m_Localized: 連擊數會延續到之後的回合中。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891786207232
    m_Localized: 在每回合開始時，無需消耗資源即可直接發動{GlobalKeywords.Crawler}的能力效果。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 2090517650202629
    m_Localized: 回合間保留最多 {Arcana.EffectValue.0:N0} 點{GlobalKeywords.Mana}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 68412324314165248
    m_Localized: 法力虹吸
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324335136768
    m_Localized: 每打出 {Arcana.EffectValue.1:N0} 張卡牌，便會永久增加{GlobalKeywords.Mana}一次。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 68794967023235072
    m_Localized: 膨脹之拳
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967035817984
    m_Localized: 在結束回合結束時，造成等同於你{GlobalKeywords.DeckPile}大小的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 69086584003178496
    m_Localized: 實驗性藥物
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 69086584024150016
    m_Localized: 使所有的治療效果加倍。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384826499072
    m_Localized: 進行地城探索時，可以多獲得一張萬用卡。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053504
    m_Localized: 將{GlobalKeywords.Crawlers}的卡牌移至你的{GlobalKeywords.Deck}頂端。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 91224384860053505
    m_Localized: 在打出卡牌時，造成等同於{GlobalKeywords.Armor}值的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 91224384860053506
    m_Localized: 從光源處拾取的卡牌可獲得連段加成。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053507
    m_Localized: '{GlobalKeywords.Armor}的效果可以延續到之後的回合中。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 91224384860053508
    m_Localized: 在本回合內，你可以免費打出相同的卡牌。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053509
    m_Localized: 連擊數在各回合間不會重置。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053510
    m_Localized: 在回合開始時，觸發能力效果。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053511
    m_Localized: 回合間保留最多 {Arcana.EffectValue.0:N0} 點{GlobalKeywords.Mana}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 91224384860053512
    m_Localized: 每打出 {Arcana.EffectValue.1:N0} 張卡牌，增加{GlobalKeywords.Mana}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 91224384860053513
    m_Localized: 在回合結束後，造成等同於{GlobalKeywords.DeckPile}大小的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 91224384860053514
    m_Localized: 治療效果加倍。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 164759920689754112
    m_Localized: 在回合結束後，造成等同於{GlobalKeywords.DeckPile}大小 {Arcana.EffectValue.0:N0} 倍的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 164759920714919936
    m_Localized: 在回合結束後，根據{GlobalKeywords.DeckPile}大小造成倍數傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  - m_Id: 164759920714919937
    m_Localized: 在每一回合結束以後，造成等同於你{GlobalKeywords.DeckPile}大小 {Arcana.EffectValue.0:N0} 倍的傷害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365316
  references: {}

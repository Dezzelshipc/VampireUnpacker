  m_Name: Dungeons_zh-Hans
  m_EditorClassIdentifier:
  m_LocaleId:
    m_Code: zh-Hans
  m_SharedData: {fileID: 11400000, guid: b7fe2d760b8956143ad9958527e67a27, type: 2}
  m_Metadata:
    m_Items:
      Array:
      - rid: 1186001538324365355
  m_TableData:
  - m_Id: 11823947247616
    m_Localized: '{GlobalKeywords.Village}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365355
  - m_Id: 11824022745088
    m_Localized: 戈顿村，一个寂静、偏僻的小村庄。但不要被它宁静的表象所欺骗——这里可是荟聚各路英杰的熔炉，冒险者征程的起点！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745089
    m_Localized: 疯狂森林
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745090
    m_Localized: 这里曾是一个生机勃勃的避风港，如今却成了藏污纳垢的魔窟。据说是一只吸血鬼引发了这里的一切邪恶，但除了混乱和烤鸡，我们在这里别无所获。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 12266632501878784
    m_Localized: 暴怒森林
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 12266632527044608
    m_Localized: 愈往森林深处，里面的怪物就愈发狂暴。空气中肯定有什么在搅乱它们的神志——黑魔法，抑或是劣质的鸡。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 12266632527044609
    m_Localized: 狂暴森林
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 12266632527044610
    m_Localized: 一旦进入这幽暗深处，便再无回头路可走。林木之间传来沉闷的哭喊，伴随着千翅拍打之声逐渐消逝。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745091
    m_Localized: 锦钿书库
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745092
    m_Localized: 身负诅咒的徒然学士不得不记住世间全部的知识，却不能理解一星半点。他的无尽书库或许能为我们提供一点参考……或是灾厄。这里有一个石质的面具，不断地轻声地低语着。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002012160000
    m_Localized: 书库西翼
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714432
    m_Localized: 在这座由书架和被诅咒的书籍组成的迷宫之中，任何理智尚存的入侵者都不敢抬高一丝音量。非人生物在厅堂之中潜行，寻求迟来已久的复仇。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714433
    m_Localized: 书库圣所
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714434
    m_Localized: 曾经世上最富智慧、最具才华的一群法师以此为家，如今一切荡然无存，只余黑暗魔法、邪恶使魔，还有那些想要控制它们的人。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745093
    m_Localized: 乳品厂
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745094
    m_Localized: 乳品魔法的发源地如今一片混乱，这里会凝固的不光是鲜血。在这群魔乱舞的工厂里，奶油味的惊喜正等待着勇士来一探究竟。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714435
    m_Localized: 牛奶厂
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714436
    m_Localized: 从前，腐败的官员通过刮掉上层的皮中饱私囊。如今这里只剩下遍布管道的迷宫，其间徘徊着曾经保护此地的巨型魔像的鬼影。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714437
    m_Localized: 凝乳厂
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714438
    m_Localized: 乳品工业区的中心，众多乳臭未干的冒险者在这里感受到了奇耻大辱。小心为牛乳而疯狂的野兽和原始的乳白魔法。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745095
    m_Localized: 擎天塔
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745096
    m_Localized: 在这座科学与巫术的高塔中，种种骇人的行径用进步的旗号加以包装。其中的众多造物与实验或许能带我们找到一直在寻觅的目标。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745097
    m_Localized: 大教堂
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 11824022745098
    m_Localized: 当他们昔日位高权重时，是多么傲慢自负，如今却成了这副摇尾乞怜的模样。这个堕落的圣地是寻找吸血鬼的最佳场所，可能是吧。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714439
    m_Localized: 终极教堂
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 40868002045714440
    m_Localized: 王座房间漂浮于此，其中的傀儡师们操控手中的丝线，编织着这片土地所有的悲苦。幻想自己为神、却在腐烂中打滚者的确适合停驻此地。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 5409240946401281
    m_Localized: 小小桥
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 5409240946401282
    m_Localized: 这座漂亮的小桥看着多么安全，肯定可以顺顺当当地过去。反正绝对要比游过去好。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 5409240946401283
    m_Localized: 迷你桥
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 5409240946401284
    m_Localized: 这座桥看起来比上一座还要小，还更安静。毫无疑问，这次必定可以安安稳稳地跨过去。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 5409240946401285
    m_Localized: 小气桥
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 5409240946401286
    m_Localized: 这座桥看着毫无威胁，只是名字有一点奇怪，怎么可能会出问题呢？
    m_Metadata:
      m_Items:
        Array: []
  references: {}

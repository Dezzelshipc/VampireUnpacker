  - m_Id: 15233277672546304
    m_Localized: Richiamo per Crawler
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 15241736912580608
    m_Localized: Rimuove l'effetto Distruzione.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 15250719622815744
    m_Localized: Eco
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 15250719660564480
    m_Localized: Riproduce l'effetto della carta precedente.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17662590428520448
    m_Localized: Rinforzo
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17662590441103360
    m_Localized: Le carte hanno meno probabilità di distruggersi.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17789179818618880
    m_Localized: Distruzione
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17789179860561920
    m_Localized: La carta si brucia, ma conferisce monete.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 19621487362125824
    m_Localized: Dadi
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 19621487362125825
    m_Localized: Conferiscono un {GlobalKeywords.Reroll} ogni 6 utilizzi.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1496553099325603845
  - m_Id: 50299978445172736
    m_Localized: Ti permette di usare la prossima carta per aumentare o diminuire la {GlobalKeywords.Combo}.
    m_Metadata:

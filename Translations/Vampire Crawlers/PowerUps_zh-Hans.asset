  m_TableData:
  - m_Id: 1803676626944
    m_Localized: 每强化一层，造成的伤害+{PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615731089408
    m_Localized: 增加伤害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 1803680821249
    m_Localized: 每强化一层，{GlobalKeywords.Armor}+{PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615756255232
    m_Localized: 减少受到的伤害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 1803680821251
    m_Localized: 每强化一层，{GlobalKeywords.MaxHealth}+{PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615756255233
    m_Localized: 提升{GlobalKeywords.MaxHealth}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 4891401596929
    m_Localized: 每强化一层，{GlobalKeywords.Mana}+{PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615756255234
    m_Localized: 增加{GlobalKeywords.Mana}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 4891401596931
    m_Localized: 每强化一层，每场遭遇战后恢复{PowerUpValue:N0}点生命值。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449536
    m_Localized: 每场遭遇战后恢复生命值。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 14110645366784
    m_Localized: 每强化一层，武器发射的{PowerUpValue:p:飞射物|飞射物}+{PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449537
    m_Localized: 武器发射更多的飞射物。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 14110645366786
    m_Localized: 攻击造成溅射伤害。每强化一层，+{PowerUpValue:N0}%伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449538
    m_Localized: 造成溅射伤害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 23295198048257
    m_Localized: 每强化一层，获得的经验值+{PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449539
    m_Localized: 获得更多经验值。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 23295198048259
    m_Localized: 每强化一层，获得的金币+{PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449540
    m_Localized: 获得更多金币。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 23295198048261
    m_Localized: 每强化一层，{GlobalKeywords.Luck}+{PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449541
    m_Localized: 提升好运几率。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2192685012168704
    m_Localized: 每强化一层，抽牌效果的{PowerUpValue:p:牌|牌}数+{PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449542
    m_Localized: 增加抽牌效果抽取的牌数。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2192685012168706
    m_Localized: 每强化一层，{GlobalKeywords.Handsize}的{PowerUpValue:p:牌|牌}数+{PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449543
    m_Localized: 增加{GlobalKeywords.Handsize}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 2283735013732352
    m_Localized: 每强化一层，{GlobalKeywords.Crawlers}停留的{GlobalKeywords.Duration}+{PowerUpValue:N0}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449544
    m_Localized: '{GlobalKeywords.Crawlers}将执行更多触发行动。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 2283735013732354
    m_Localized: 每强化一层，你在升级选择时便可移除{PowerUpValue:N0}张{PowerUpValue:p:牌|牌}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449545
    m_Localized: 升级时可移除卡牌选项。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2283735013732356
    m_Localized: 每强化一层，可获得{PowerUpValue:N0}个{GlobalKeywords.Reroll}选项。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449546
    m_Localized: 可获得{GlobalKeywords.Reroll}选项。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 2283735013732358
    m_Localized: '{GlobalKeywords.Skip}选项，改为获得经验值。每强化一层，+{PowerUpValue:N0}。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449547
    m_Localized: '{GlobalKeywords.Skip}选项，改为获得经验值。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 2541682885210112
    m_Localized: 即将死亡时，每强化一层，可{GlobalKeywords.Revive}一次。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449548
    m_Localized: 即将死亡时可{GlobalKeywords.Revive}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 18138219010928640
    m_Localized: 每强化一层，敌方力量+{PowerUpValue:N0}%，但己方会获得额外的经验值。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 84069615760449550
    m_Localized: 增加敌方力量，但会获得额外的经验值。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 43555440361025536
    m_Localized: 每强化一层，额外增加一个{GlobalKeywords.Crawler}槽位。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 96079886660087808
    m_Localized: 每强化一层，敌方速度、生命值和数量+{PowerUpValue:N0}%。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 170475265769549824
    m_Localized: 额外击中目标。每强化一层，+{PowerUpValue:N0}%伤害。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365360
  - m_Id: 170475265794715648
    m_Localized: 额外击中目标。
    m_Metadata:
      m_Items:
        Array: []
  references: {}

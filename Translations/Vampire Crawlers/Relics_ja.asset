      - rid: 1186001538324365352
  m_TableData:
  - m_Id: 633881047040
    m_Localized: 天の川の地図
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018560
    m_Localized: 敵の配置などをミニマップに表示。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018561
    m_Localized: 魔導書
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018562
    m_Localized: 発見した武器の進化形や融合のリストを一時停止メニューに追加。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212864
    m_Localized: 魔法の楽器
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212866
    m_Localized: 魔女の涙
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212867
    m_Localized: ワールドマップに「スピード」ボタンを追加。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212868
    m_Localized: 数奇のカード
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212869
    m_Localized: ダンジョンに{GlobalKeywords.Arcana}イベントを追加。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 633906212870
    m_Localized: ガラスのお面
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212872
    m_Localized: 黄の印
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212874
    m_Localized: 大いなる福音
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212876
    m_Localized: グラシアの鏡
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212878
    m_Localized: 勇敢な物語
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212880
    m_Localized: オーバーキル
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212881
    m_Localized: ボスを倒してなお攻撃を続けて、コインを獲得する。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212882
    m_Localized: コンボスタック
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212883
    m_Localized: '{0} {:color(Mana):{GlobalKeywords.Mana} コスト}の昇順でカードを使用すると、コンボ倍増が加算される。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 633906212884
    m_Localized: デッキボックス
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212885
    m_Localized: カードのデッキを収納できるシンプルな箱。村の外に出るなら絶対に持っておきたい必需品！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212886
    m_Localized: ボンバ・インフェルナーレ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212887
    m_Localized: すでにクリアしたダンジョンの1階層にいる敵すべてを、瞬時に蒸発させる。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212890
    m_Localized: ライレヴァトーレ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212891
    m_Localized: 武器が敵に与える影響を可視化する。それに、とにかく見た目がカッコいい。着れば爆モテ間違いなしだ！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17309176422281216
    m_Localized: 錆びたカギ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17309176439058432
    m_Localized: 宿屋ゴートン・ベルの錆びついたカギ。町で一番ホットなこの場所は、{:color(Relic):新たな{GlobalKeywords.Crawlers}を仲間に誘うのにうってつけの場所だ}。パイントでミルクを楽しみたい時にもおすすめ。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 18050765490827264
    m_Localized: ダルカッソ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 20545961352835072
    m_Localized: 究極のウルトラ・オーバーキル
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 20545961365417984
    m_Localized: '{db.relic.RelicConfig_Overkill.Name}を限界突破させる。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 31106417456918528
    m_Localized: ポレンティル
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 31106417477890048
    m_Localized: '{GlobalKeywords.Village}にある占い師の{GlobalKeywords.Arcana}テントをアンロックする。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 32524480840544256
    m_Localized: 導きの光
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 32524480861515776
    m_Localized: ミニマップ上に破壊可能な光源を表示する。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50632878304665600
    m_Localized: オヴェンキルト
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50632878321442816
    m_Localized: どんなエンカウンターでも{db.relic.RelicConfig_Overkill.Name}が可能になる。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 58306081112186880
    m_Localized: ミニマップ上で破壊可能な光源と{GlobalKeywords.Relics}を表示する。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 101974478517383168
    m_Localized: '{GlobalKeywords.DeckPile}と{GlobalKeywords.DiscardPile}をアンロックする。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 73897861531643904
    m_Localized: ジェムハンマー
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 73897861540032512
    m_Localized: ジェムをカードに追加できるようになる。\n宝箱またはレベルアップ時にジェムを見つけよう。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 85855072138899456
    m_Localized: '{GlobalKeywords.Crawlers}チュートリアル'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 85855072164065280
    m_Localized: クロウラーは、戦闘で対応する色のカードをプレイする際に役立つ。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797238063104
    m_Localized: 星屑のアンヴィル
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797263228928
    m_Localized: '{GlobalKeywords.Village}にある{GlobalKeywords.Blacksmith}の作業場をアンロックする。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 96732797267423232
    m_Localized: 宝石売りのルーペ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797267423233
    m_Localized: '{GlobalKeywords.Blacksmith}にある{GlobalKeywords.Jeweller}のカウンターをアンロックする。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 139155747105660928
    m_Localized: ダンジョンに{GlobalKeywords.Arcana}宝箱を追加。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365352
  - m_Id: 139227927105449984
    m_Localized: アルカナファインダー
    m_Metadata:
      m_Items:
        Array: []
  references: {}

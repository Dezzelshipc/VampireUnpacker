%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 1aac8e9c81dd1c685a0bf64c67249e0c, type: 3}
  m_Name: Arcanas_ja
  m_EditorClassIdentifier:
  m_LocaleId:
    m_Code: ja
  m_SharedData: {fileID: 11400000, guid: b5d003cb409f9ad47abc92d84037d93d, type: 2}
  m_Metadata:
    m_Items:
      Array:
      - rid: 1186001538324365330
  m_TableData:
  - m_Id: 50305010928328704
    m_Localized: 道化師の帽子
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51317535027372032
    m_Localized: 限界突破
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202624
    m_Localized: シールドバッシュ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202625
    m_Localized: ワイルドバフ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202626
    m_Localized: 忠盾の誓い
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50305010953494528
    m_Localized: 各フロア開始時に、自分の{GlobalKeywords.Deck}にワイルドカードを追加。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 51317535044149248
    m_Localized: '{GlobalKeywords.Crawler}が去る時、自分の{GlobalKeywords.Deck}の一番上に置く。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 2090517650202630
    m_Localized: '{GlobalKeywords.Armor}カードをプレイした後、合計{GlobalKeywords.Armor}をダメージとして前列に食らわせる。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 2090517650202631
    m_Localized: 光源から回収したカードはコンボ倍増の恩恵を受けられるようになった。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202632
    m_Localized: 残りの{GlobalKeywords.Armor}は次のターンへ引き継がれる。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 53171049999507456
    m_Localized: おまけにもうひとつ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577568325632
    m_Localized: チェーンリンク
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891761041408
    m_Localized: 大暴れ
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517646008321
    m_Localized: 切れ者
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171050016284672
    m_Localized: このターン中に同種のカードがプレイされていれば、このカードは{GlobalKeywords.TypeFree}になる。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 53870577597685760
    m_Localized: コンボはターンをまたいでもリセットされない。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891786207232
    m_Localized: 各ターン開始時に、{GlobalKeywords.Crawler}の誘発効果を無料で発動する。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 2090517650202629
    m_Localized: '{GlobalKeywords.Mana}を最大{Arcana.EffectValue.0:N0}まで次のターンに持ち越す。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 68412324314165248
    m_Localized: マナ・サイフォン
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324335136768
    m_Localized: プレイした{Arcana.EffectValue.1:N0}カードそれぞれにつき、{GlobalKeywords.Mana}を永久的に増加。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 68794967023235072
    m_Localized: 膨張の拳
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967035817984
    m_Localized: 毎ターン終了時に{GlobalKeywords.DeckPile}のサイズに応じたダメージを与える。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 69086584003178496
    m_Localized: 実験薬
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 69086584024150016
    m_Localized: 回復効果を2倍にする。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384826499072
    m_Localized: 各フロアでワイルドカードを追加。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053504
    m_Localized: '{GlobalKeywords.Crawlers}を{GlobalKeywords.Deck}の一番上に移動する。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 91224384860053505
    m_Localized: プレイ時に{GlobalKeywords.Armor}をダメージとして与える。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 91224384860053506
    m_Localized: 光源から回収したカードはコンボ倍増を得る。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053507
    m_Localized: '{GlobalKeywords.Armor}が継続。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 91224384860053508
    m_Localized: このターンで再使用されるカードはフリータイプになる。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053509
    m_Localized: コンボはターンをまたいでもリセットされない。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053510
    m_Localized: ターン開始時に能力を誘発。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053511
    m_Localized: '{GlobalKeywords.Mana}を最大{Arcana.EffectValue.0:N0}まで次のターンに持ち越す。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 91224384860053512
    m_Localized: '{Arcana.EffectValue.1:N0}カードをプレイするたびに{GlobalKeywords.Mana}が増加。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 91224384860053513
    m_Localized: ターン後に{GlobalKeywords.DeckPile}をダメージとして与える。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 91224384860053514
    m_Localized: ダブルヒール付与。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 164759920689754112
    m_Localized: "ターン後、{Arcana.EffectValue.0:N0}×{GlobalKeywords.DeckPile}のダメージを与える。\n\n"
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 164759920714919936
    m_Localized: "ターン後、{GlobalKeywords.DeckPile}のダメージを与える。\n\n"
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  - m_Id: 164759920714919937
    m_Localized: "毎ターン時、{Arcana.EffectValue.0:N0}×{GlobalKeywords.DeckPile}のサイズに応じてダメージを与える。\n\n"
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365330
  references: {}

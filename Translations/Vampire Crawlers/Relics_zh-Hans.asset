  m_TableData:
  - m_Id: 633881047040
    m_Localized: 星河图
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018560
    m_Localized: 在小地图上显示敌方位置等信息。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018561
    m_Localized: 邪恶秘典
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018562
    m_Localized: 在暂停菜单界面中添加已发现的武器进化和组合列表。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212864
    m_Localized: 热歌香肠
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212866
    m_Localized: 女巫的眼泪
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212867
    m_Localized: 在世界地图上添加倍速按钮。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212868
    m_Localized: 秘法牌
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212869
    m_Localized: 给地下城添加{GlobalKeywords.Arcana}事件。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 633906212870
    m_Localized: 玻璃护面
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212872
    m_Localized: 黄色秘符
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212874
    m_Localized: 福音书
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212876
    m_Localized: 格拉西娅的魔镜
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212878
    m_Localized: 勇敢故事
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212880
    m_Localized: 鞭尸
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212881
    m_Localized: 继续攻击已打败的头目以赚取金币。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212882
    m_Localized: 煎饼叠叠高
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212883
    m_Localized: 按照{0}{:color(Mana):{GlobalKeywords.Mana}消耗}从小到大的顺序打出卡牌可获得连击倍数。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 633906212884
    m_Localized: 牌组盒
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212885
    m_Localized: 简简单单的盒子，里面放着一副卡牌。离开村庄出行时不带着它是万万不行的！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212886
    m_Localized: 地狱炸弹
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212887
    m_Localized: 让你曾通关的地下城第一层的所有敌人即刻蒸发。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212890
    m_Localized: 探测镜
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212891
    m_Localized: 显示武器将对目标造成的影响。而且你戴着这东西酷毙了。秒变万人迷！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17309176422281216
    m_Localized: 生锈钥匙
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17309176439058432
    m_Localized: 一把生锈的旧钥匙，用来打开戈顿·贝尔旅馆的门。你可以在旅馆热火朝天地{:color(Relic):招募新的{GlobalKeywords.Crawlers}作战}，或者悠闲自在地喝杯牛奶。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 18050765490827264
    m_Localized: 黑魔牌
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 20545961352835072
    m_Localized: 无尽鞭尸
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 20545961365417984
    m_Localized: '{db.relic.RelicConfig_Overkill.Name}突破极限。'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 31106417456918528
    m_Localized: 魔眼糊
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 31106417477890048
    m_Localized: 在{GlobalKeywords.Village}解锁占卜师的{GlobalKeywords.Arcana}帐篷。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 32524480840544256
    m_Localized: 指引之光
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 32524480861515776
    m_Localized: 在小地图上显示可打破的光源。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50632878304665600
    m_Localized: 无金鞭尸
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50632878321442816
    m_Localized: 在任意遭遇战中{db.relic.RelicConfig_Overkill.Name}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 58306081112186880
    m_Localized: 在小地图上显示可打破的光源和{GlobalKeywords.Relics}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 101974478517383168
    m_Localized: 解锁{GlobalKeywords.DeckPile}和{GlobalKeywords.DiscardPile}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 73897861531643904
    m_Localized: 宝石锤子
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 73897861540032512
    m_Localized: 解锁给卡牌添加宝石的能力。\n宝石可在宝箱中或升级时获得。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 85855072138899456
    m_Localized: '{GlobalKeywords.Crawlers}教程'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 85855072164065280
    m_Localized: 探索者会在战斗中助你一臂之力，条件是打出与之对应颜色的卡牌。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797238063104
    m_Localized: 星尘铁砧
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797263228928
    m_Localized: 在{GlobalKeywords.Village}中解锁{GlobalKeywords.Blacksmith}的工坊。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 96732797267423232
    m_Localized: 宝石放大镜
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797267423233
    m_Localized: 在{GlobalKeywords.Blacksmith}处解锁{GlobalKeywords.Jeweller}的柜台。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 139155747105660928
    m_Localized: 给地下城添加{GlobalKeywords.Arcana}宝箱。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365317
  - m_Id: 139227927105449984
    m_Localized: 秘能探测者
    m_Metadata:
      m_Items:
        Array: []
  references: {}

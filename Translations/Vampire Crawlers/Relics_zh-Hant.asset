  m_TableData:
  - m_Id: 633881047040
    m_Localized: 星河圖
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018560
    m_Localized: 在小地圖上將敵人位置等等的資訊標示出來。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018561
    m_Localized: 邪惡魔典
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633902018562
    m_Localized: 在暫停選單中新增已知的武器解放與組合列表。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212864
    m_Localized: 熱歌香腸
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212866
    m_Localized: 女巫的眼淚
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212867
    m_Localized: 在地圖介面中，加入「加速」的按鈕。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212868
    m_Localized: 秘法牌
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212869
    m_Localized: 在地城中新增{GlobalKeywords.Arcana}事件。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 633906212870
    m_Localized: 玻璃護面
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212872
    m_Localized: 黃色秘符
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212874
    m_Localized: 福音書
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212876
    m_Localized: 格拉西雅的魔鏡
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212878
    m_Localized: 勇敢事蹟
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212880
    m_Localized: 趕盡殺絕
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212881
    m_Localized: 持續攻擊已倒下的 Boss 以賺取金幣。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212882
    m_Localized: 連段堆疊
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212883
    m_Localized: 依照 {0} {:color(Mana):{GlobalKeywords.Mana}消耗量}的遞增順序出牌以獲得倍率加成。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 633906212884
    m_Localized: 卡牌盒
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212885
    m_Localized: 一個可以用來帶上牌組的簡單盒子。在離開村莊之前，所有人最好都要帶上一個！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212886
    m_Localized: 地獄炸彈
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212887
    m_Localized: 在你先前已通關的地城冒險中，將身處地城第一層的所有敵人通通都立即「燒毀」。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212890
    m_Localized: 探測器
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 633906212891
    m_Localized: 讓你可以有效掌握你的武器會對目標造成什麼樣的打擊。而且啊，這個小玩意兒戴起來超酷的。戴上探測器的你根本魅力無法擋！
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17309176422281216
    m_Localized: 生鏽的鑰匙
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 17309176439058432
    m_Localized: 一把用來前往戈頓鐘旅店的生鏽老舊鑰匙。戈頓鐘旅店可說是全鎮最潮最酷的地方，你可以來這裡{:color(Relic):招募全新的{GlobalKeywords.Crawlers}加入你的冒險行列}，或是單純來喝杯牛奶放鬆一下。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 18050765490827264
    m_Localized: 黑暗秘法牌
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 20545961352835072
    m_Localized: 終極無敵趕盡殺絕
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 20545961365417984
    m_Localized: 突破{db.relic.RelicConfig_Overkill.Name}的極限。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 31106417456918528
    m_Localized: 波倫提爾
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 31106417477890048
    m_Localized: 在{GlobalKeywords.Village}中解鎖算命師的{GlobalKeywords.Arcana}帳篷。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 32524480840544256
    m_Localized: 指引明燈
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 32524480861515776
    m_Localized: 在小地圖上將可破壞的光源標記出來。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50632878304665600
    m_Localized: 絕命手套
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50632878321442816
    m_Localized: 讓你在任何一場戰鬥中，皆能夠觸發「{db.relic.RelicConfig_Overkill.Name}」的效果。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 58306081112186880
    m_Localized: 在小地圖上將可破壞的光源與{GlobalKeywords.Relics}標記出來。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 101974478517383168
    m_Localized: 解鎖{GlobalKeywords.DeckPile}與{GlobalKeywords.DiscardPile}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 73897861531643904
    m_Localized: 寶石鎚
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 73897861540032512
    m_Localized: 解鎖為卡牌鑲嵌寶石的能力。\n你有機會可以在寶箱中（或是升級時）找到寶石。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 85855072138899456
    m_Localized: '{GlobalKeywords.Crawlers}教學'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 85855072164065280
    m_Localized: 在你打出了對應顏色的卡牌之後，冒險者便會在戰鬥中助你一臂之力。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797238063104
    m_Localized: 星塵鐵砧
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797263228928
    m_Localized: 在{GlobalKeywords.Village}中，解鎖{GlobalKeywords.Blacksmith}工作坊。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 96732797267423232
    m_Localized: 寶石放大鏡
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 96732797267423233
    m_Localized: 在{GlobalKeywords.Blacksmith}中，解鎖{GlobalKeywords.Jeweller}的櫃檯。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 139155747105660928
    m_Localized: 在地城中加入{GlobalKeywords.Arcana}寶箱。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365345
  - m_Id: 139227927105449984
    m_Localized: 秘法牌探測器
    m_Metadata:
      m_Items:
        Array: []
  references: {}

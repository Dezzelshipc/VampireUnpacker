    m_Localized: '{:color(Keyword):{GlobalKeywords.Growth}}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034508
    m_Localized: 獲得更多經驗值。
    m_Metadata:
      m_Items:
        Array: []

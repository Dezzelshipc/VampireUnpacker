    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 130811107127406595
    m_Localized: 減少 {ActionValue:N0} 點的{GlobalKeywords.Mana}消耗。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356

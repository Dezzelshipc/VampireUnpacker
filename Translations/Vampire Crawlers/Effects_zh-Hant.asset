    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034518
    m_Localized: 提高 {ActionValue:N0} 點的{GlobalKeywords.MaxHealth}。
    m_Metadata:
      m_Items:
        Array:

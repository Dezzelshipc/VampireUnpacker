    m_Localized: '{:color(Keyword):減少}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034530
    m_Localized: 減少{GlobalKeywords.Hand}中所有卡牌的消耗數值。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034531
    m_Localized: '{:color(Keyword):{GlobalKeywords.Reroll}}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034532

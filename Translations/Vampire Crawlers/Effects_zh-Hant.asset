    m_Localized: 棄牌時：{0}
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 131544377140961280
    m_Localized: 回合結束時：{0}
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 131544377140961281

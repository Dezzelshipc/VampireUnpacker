    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034504
    m_Localized: 獲得 {ActionValue:N0} 點的{GlobalKeywords.Mana}。
    m_Metadata:

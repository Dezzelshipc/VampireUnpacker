  - m_Id: 128673243539255296
    m_Localized: '{CardType.Icon} {CardType.Name}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128673243564421120
    m_Localized: 觸發冒險者的能力。

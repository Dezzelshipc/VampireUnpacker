  - m_Id: 128589568957034514
    m_Localized: 為你帶來好{GlobalKeywords.Luck}。
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034515
    m_Localized: '{:color(Keyword):{GlobalKeywords.Magnet}}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365356
  - m_Id: 128589568957034516
    m_Localized: 提高{GlobalKeywords.Draw}效果的卡牌抽取數。

        Array:
        - rid: 1186001538324365356
  - m_Id: 131170478754619392
    m_Localized: 對一名隨機敵人造成等同於當前總擊殺數的傷害。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 130811107106435072
    m_Localized: 普通
    m_Metadata:
      m_Items:
        Array: []

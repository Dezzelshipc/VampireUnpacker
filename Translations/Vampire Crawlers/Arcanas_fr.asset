        Array: []
  - m_Id: 2090517650202626
    m_Localized: Votre bouclier, Monseigneur
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50305010953494528
    m_Localized: Ajoute une carte joker à votre {GlobalKeywords.Deck} au début de chaque niveau.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 51317535044149248
    m_Localized: Lorsqu'un {GlobalKeywords.Crawler} part, positionnez-le sur le dessus de votre {GlobalKeywords.Deck}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 2090517650202630
    m_Localized: Vous infligez des dégâts égaux à la valeur totale de votre {GlobalKeywords.Armor} au premier rang après avoir joué une carte {GlobalKeywords.Armor}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 2090517650202631
    m_Localized: Les cartes obtenues via les sources de lumière bénéficient désormais des multiplicateurs de combo.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202632
    m_Localized: L'{GlobalKeywords.Armor} restante persiste entre les tours.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 53171049999507456
    m_Localized: Et une autre
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577568325632
    m_Localized: Enchaînement
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891761041408
    m_Localized: Crise de nerfs
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517646008321
    m_Localized: Esprit vif
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171050016284672
    m_Localized: Les cartes sont gratuites si une version de ces dernières a été jouée pendant ce tour.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577597685760
    m_Localized: Les combos ne se réinitialisent pas entre chaque tour.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891786207232
    m_Localized: Active les capacités déclenchables des {GlobalKeywords.Crawler} gratuitement au début de chaque tour.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 2090517650202629
    m_Localized: Vous gardez jusqu'à {Arcana.EffectValue.0:N0} de {GlobalKeywords.Mana} entre les tours.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 68412324314165248
    m_Localized: Siphon de mana
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324335136768
    m_Localized: Augmente le {GlobalKeywords.Mana} de manière permanente après toutes les {Arcana.EffectValue.1:N0} cartes jouées.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318
  - m_Id: 68794967023235072
    m_Localized: Poing enflé
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967035817984
    m_Localized: Vous infligez des dégâts en fonction de la taille de votre {GlobalKeywords.DeckPile} à la fin de chaque tour.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365318

  m_LocaleId:
    m_Code: de
  m_SharedData: {fileID: 11400000, guid: b5d003cb409f9ad47abc92d84037d93d, type: 2}
  m_Metadata:
    m_Items:
      Array:
      - rid: 1186001538324365314
  m_TableData:
  - m_Id: 50305010928328704
    m_Localized: Narrenkappe
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51317535027372032
    m_Localized: Auf die Spitze
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202624
    m_Localized: Schildschlag
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202625
    m_Localized: Wilde Stärke
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202626
    m_Localized: Mit Schild und Panzer
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 50305010953494528
    m_Localized: Mische zu Beginn jeder Ebene eine wilde Karte in dein {GlobalKeywords.Deck}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 51317535044149248
    m_Localized: Wenn ein {GlobalKeywords.Crawler} verschwindet, lege ihn ganz oben auf dein {GlobalKeywords.Deck}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 2090517650202630
    m_Localized: Verursacht deinen {GlobalKeywords.Armor}swert als Schaden an der vorderen Reihe, wenn du "{GlobalKeywords.Armor}"-Karten spielst.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 2090517650202631
    m_Localized: Karten aus Lichtquellen profitieren nun von Kombo-Multiplikatoren.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517650202632
    m_Localized: Verbleibende {GlobalKeywords.Armor} verfällt nicht mehr zwischen Zügen.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 53171049999507456
    m_Localized: Noch eine Runde
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577568325632
    m_Localized: Verknüpfte Ketten
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891761041408
    m_Localized: Aus den Vollen
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 2090517646008321
    m_Localized: Geübter Geist
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53171050016284672
    m_Localized: Nach dem Ausspielen einer Karte sind alle weiteren Versionen dieser Karte in dieser Runde kostenlos.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 53870577597685760
    m_Localized: Kombos werden zwischen den Runden nicht zurückgesetzt.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 51400891786207232
    m_Localized: '{GlobalKeywords.Crawler}-Fähigkeiten werden zu Beginn jeder Runde kostenlos ausgelöst.'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 2090517650202629
    m_Localized: Du kannst bis zu {Arcana.EffectValue.0:N0} {GlobalKeywords.Mana} für die nächste Runde aufbewahren.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 68412324314165248
    m_Localized: Mana-Wiederverwertung
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68412324335136768
    m_Localized: Du erhältst nach {Arcana.EffectValue.1:N0} ausgespielten Karten dauerhaft mehr {GlobalKeywords.Mana}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 68794967023235072
    m_Localized: Von langer Hand
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 68794967035817984
    m_Localized: Am Ende jeder Runde verursachst du Schaden in Höhe der Anzahl an Karten in deinem {GlobalKeywords.DeckPile}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 69086584003178496
    m_Localized: Experimentelle Arznei
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 69086584024150016
    m_Localized: Alle Heileffekte werden verdoppelt.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384826499072
    m_Localized: Eine wilde Karte auf jeder Ebene.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053504
    m_Localized: '{GlobalKeywords.Crawlers} landen ganz oben auf dem {GlobalKeywords.Deck}.'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 91224384860053505
    m_Localized: '{GlobalKeywords.Armor} verursacht Schaden beim Ausspielen.'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 91224384860053506
    m_Localized: Lichtquellenkarten nutzen Kombo-Multiplikatoren.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053507
    m_Localized: '{GlobalKeywords.Armor} ist nun dauerhaft.'
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 91224384860053508
    m_Localized: Kopien sind diesen Zug lang kostenlos.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053509
    m_Localized: Kombos werden nicht zurückgesetzt.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053510
    m_Localized: Fähigkeiten werden jede Runde ausgelöst.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 91224384860053511
    m_Localized: Du kannst bis zu {Arcana.EffectValue.0:N0} {GlobalKeywords.Mana} für die nächste Runde aufbewahren.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 91224384860053512
    m_Localized: Du bekommst alle {Arcana.EffectValue.1:N0} Karten dauerhaft {GlobalKeywords.Mana}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 91224384860053513
    m_Localized: Schaden in Höhe vom {GlobalKeywords.DeckPile} am Ende der Runde.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 91224384860053514
    m_Localized: Heilung verdoppelt.
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 164759920689754112
    m_Localized: Schaden in Höhe von {Arcana.EffectValue.0:N0}x {GlobalKeywords.DeckPile} am Ende der Runde.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 164759920714919936
    m_Localized: Schaden in Abhängigkeit von {GlobalKeywords.DeckPile} am Rundenende.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  - m_Id: 164759920714919937
    m_Localized: Du verursachst am Ende jeder Runde Schaden in Höhe des {Arcana.EffectValue.0:N0}-Fachen der Anzahl der Karten in deinem {GlobalKeywords.DeckPile}.
    m_Metadata:
      m_Items:
        Array:
        - rid: 1186001538324365314
  references: {}

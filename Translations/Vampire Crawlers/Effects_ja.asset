    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 146873999923556357
    m_Localized: '{:color(Keyword):クロウラーコール}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 146873999923556358
    m_Localized: 全{GlobalKeywords.Crawlers}を{GlobalKeywords.Hand}に召喚する。
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 147166005589651456
    m_Localized: '{:color(Keyword):遠隔}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 147166005639983104
    m_Localized: トロッコを召喚する。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 147166005639983105
    m_Localized: '{:color(Keyword):爆撃}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 147166005639983106
    m_Localized: チェリーボムを放つ。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 147166005639983107
    m_Localized: '{:color(Keyword):魔法の帽子}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 147166005639983108
    m_Localized: 頭上からハトを呼び寄せる。
    m_Metadata:
      m_Items:
        Array: []

      m_Items:
        Array: []
  - m_Id: 153602617303314432
    m_Localized: '{:color(Keyword):氷漬け}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 153602617349451776
    m_Localized: マナコストが一時的に増加。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 153707637365485568
    m_Localized: カードは保持されるが、プレイ時のマナコストが増加。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 153707637365485569
    m_Localized: '{:color(Keyword):ダイスロール}'
    m_Metadata:
      m_Items:
        Array:
        - rid: 2833696724673101836
  - m_Id: 153707637365485570
    m_Localized: 6回目の使用ごとに(keyword reroll???)を実行。
    m_Metadata:
      m_Items:
        Array: []
  - m_Id: 153707637365485571
